<UserControl x:Class="WpfControlLibrary1.UserControl_WorkPageDataEdit"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
            
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="850"
             d:DesignWidth="1200"
             TextElement.Foreground="{DynamicResource MaterialDesignBody}"
             Background="{DynamicResource MaterialDesignPaper}"
             FontFamily="{DynamicResource MaterialDesignFont}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="0,0,0,24"
                Padding="10"
                Background="{DynamicResource MaterialDesignCardBackground}"
                CornerRadius="8"
                >
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">

                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                CornerRadius="4"
                                Margin="0,0,16,0"
                                Padding="12,28,12,6">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderThickness"
                                            Value="1" />
                                    <Setter Property="BorderBrush"
                                            Value="#40FFFFFF" />
                                    <Setter Property="Background"
                                            Value="Transparent" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding FlashLotNo}"
                                                     Value="True">
                                            <Setter Property="BorderBrush"
                                                    Value="{DynamicResource MaterialDesign.Brush.Primary.Light}" />
                                            <Setter Property="BorderThickness"
                                                    Value="2" />
                                            <Setter Property="Background">
                                                <Setter.Value>
                                                    <SolidColorBrush Color="{DynamicResource MaterialDesign.Color.Primary}"
                                                                     Opacity="0.15" />
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBox Text="{Binding LotNo, UpdateSourceTrigger=PropertyChanged}"
                                     materialDesign:HintAssist.Hint="工單號 (刷入或輸入後按 Enter 查詢)"
                                     materialDesign:HintAssist.FloatingScale="0.55"
                                     Foreground="{DynamicResource MaterialDesignBody}"
                                     FontSize="28"
                                     FontWeight="Bold"
                                     Margin="0"
                                     Padding="0"
                                     VerticalAlignment="Bottom">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Return"
                                                Command="{Binding SearchLotNoCommand}" />
                                </TextBox.InputBindings>
                                <TextBox.Style>
                                    <Style TargetType="TextBox"
                                           BasedOn="{StaticResource MaterialDesignFloatingHintTextBox}">
                                        <Setter Property="materialDesign:TextFieldAssist.UnderlineBrush"
                                                Value="Transparent" />
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </Border>

                        <Border Grid.Column="1"
                                Background="{DynamicResource MaterialDesignTextFieldBoxDisabledBackground}"
                                CornerRadius="4"
                                Margin="0,0,16,0"
                                Padding="12,28,12,6"
                                BorderThickness="1"
                                Opacity="0.9">
                            <TextBox Text="{Binding ProductName}"
                                     materialDesign:HintAssist.Hint="品名 (Product Name)"
                                     materialDesign:HintAssist.FloatingScale="0.55"
                                     Foreground="{DynamicResource MaterialDesignBody}"
                                     FontSize="28"
                                     FontWeight="Bold"
                                     Margin="0"
                                     Padding="0"
                                     VerticalAlignment="Bottom"
                                     IsReadOnly="True"
                                     >
                                <TextBox.Style>
                                    <Style TargetType="TextBox"
                                           BasedOn="{StaticResource MaterialDesignFloatingHintTextBox}">
                                        <Setter Property="materialDesign:TextFieldAssist.UnderlineBrush"
                                                Value="Transparent" />
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </Border> 

                        <Border Grid.Column="2"
                                Background="{DynamicResource MaterialDesignTextFieldBoxDisabledBackground}"
                                CornerRadius="4"
                                Margin="0,0,0,0"
                                Padding="12,28,12,6"
                                BorderThickness="1"
                                Opacity="0.9"
                                >
                            <TextBox Text="{Binding ParentLotNo}"
                                     materialDesign:HintAssist.Hint="品名 (Product Name)"
                                     materialDesign:HintAssist.FloatingScale="0.55"
                                     Foreground="{DynamicResource MaterialDesignBody}"
                                     FontSize="28"
                                     FontWeight="Bold"
                                     Margin="0"
                                     Padding="0"
                                     VerticalAlignment="Bottom"
                                     IsReadOnly="True"
                                     
                                    >
                                <TextBox.Style>
                                    <Style TargetType="TextBox"
                                           BasedOn="{StaticResource MaterialDesignFloatingHintTextBox}">
                                        <Setter Property="materialDesign:TextFieldAssist.UnderlineBrush"
                                                Value="Transparent" />
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </Border>
                    </Grid>

                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*" />
                            <ColumnDefinition Width="1*" />
                            <ColumnDefinition Width="1.5*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                CornerRadius="4"
                                Margin="0,0,16,0"
                                Padding="12,28,12,6">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderThickness"
                                            Value="1" />
                                    <Setter Property="BorderBrush"
                                            Value="#40FFFFFF" />
                                    <Setter Property="Background"
                                            Value="Transparent" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding FlashUser}"
                                                     Value="True">
                                            <Setter Property="BorderBrush"
                                                    Value="{DynamicResource MaterialDesign.Brush.Primary.Light}" />
                                            <Setter Property="BorderThickness"
                                                    Value="2" />
                                            <Setter Property="Background">
                                                <Setter.Value>
                                                    <SolidColorBrush Color="{DynamicResource MaterialDesign.Color.Primary}"
                                                                     Opacity="0.15" />
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <ComboBox ItemsSource="{Binding UserList}"
                                      SelectedItem="{Binding SelectedUser}"
                                      materialDesign:HintAssist.Hint="生產者 (刷入員工條碼)"
                                      materialDesign:HintAssist.FloatingScale="0.55"
                                      Foreground="{DynamicResource MaterialDesignBody}"
                                      FontSize="28"
                                      FontWeight="Bold"
                                      Margin="0"
                                      Padding="0"
                                      VerticalAlignment="Bottom">
                                <ComboBox.Style>
                                    <Style TargetType="ComboBox"
                                           BasedOn="{StaticResource MaterialDesignFloatingHintComboBox}">
                                        <Setter Property="materialDesign:TextFieldAssist.UnderlineBrush"
                                                Value="Transparent" />
                                    </Style>
                                </ComboBox.Style>
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding BarCode}"
                                                       FontWeight="Bold"
                                                       Foreground="{DynamicResource MaterialDesignBody}" />
                                            <TextBlock Text=" - "
                                                       Foreground="{DynamicResource MaterialDesignBody}"
                                                       Opacity="0.7" />
                                            <TextBlock Text="{Binding Definition}"
                                                       Foreground="{DynamicResource MaterialDesignBody}"
                                                       Opacity="0.7" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </Border>

                        <Border Grid.Column="1"
                                CornerRadius="4"
                                Margin="0,0,16,0"
                                Padding="12,28,12,6">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderThickness"
                                            Value="1" />
                                    <Setter Property="BorderBrush"
                                            Value="#40FFFFFF" />
                                    <Setter Property="Background"
                                            Value="Transparent" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding FlashEqNo}"
                                                     Value="True">
                                            <Setter Property="BorderBrush"
                                                    Value="{DynamicResource MaterialDesign.Brush.Primary.Light}" />
                                            <Setter Property="BorderThickness"
                                                    Value="2" />
                                            <Setter Property="Background">
                                                <Setter.Value>
                                                    <SolidColorBrush Color="{DynamicResource MaterialDesign.Color.Primary}"
                                                                     Opacity="0.15" />
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <ComboBox ItemsSource="{Binding EqNoList}"
                                      SelectedItem="{Binding SelectedEqNo}"
                                      materialDesign:HintAssist.Hint="機台(刷入設備條碼)"
                                      materialDesign:HintAssist.FloatingScale="0.55"
                                      Foreground="{DynamicResource MaterialDesignBody}"
                                      FontSize="28"
                                      FontWeight="Bold"
                                      Margin="0"
                                      Padding="0"
                                      VerticalAlignment="Bottom">
                                <ComboBox.Style>
                                    <Style TargetType="ComboBox"
                                           BasedOn="{StaticResource MaterialDesignFloatingHintComboBox}">
                                        <Setter Property="materialDesign:TextFieldAssist.UnderlineBrush"
                                                Value="Transparent" />
                                    </Style>
                                </ComboBox.Style>
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding BarCode}"
                                                       FontWeight="Bold"
                                                       Foreground="{DynamicResource MaterialDesignBody}" />
                                            <TextBlock Text=" - "
                                                       Foreground="{DynamicResource MaterialDesignBody}"
                                                       Opacity="0.7" />
                                            <TextBlock Text="{Binding Definition}"
                                                       Foreground="{DynamicResource MaterialDesignBody}"
                                                       Opacity="0.7" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </Border>
                        
                        <Border Grid.Column="2"
                            CornerRadius="4"
                                Margin="0"
                                Padding="12,28,12,6">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderThickness"
                                            Value="1" />
                                    <Setter Property="BorderBrush"
                                            Value="#40FFFFFF" />
                                    <Setter Property="Background"
                                            Value="Transparent" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding FlashWorkStation}"
                                                     Value="True">
                                            <Setter Property="BorderBrush"
                                                    Value="{DynamicResource MaterialDesign.Brush.Primary.Light}" />
                                            <Setter Property="BorderThickness"
                                                    Value="2" />
                                            <Setter Property="Background">
                                                <Setter.Value>
                                                    <SolidColorBrush Color="{DynamicResource MaterialDesign.Color.Primary}"
                                                                     Opacity="0.15" />
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <ComboBox ItemsSource="{Binding WorkStationList}"
                                      SelectedItem="{Binding SelectedWorkStation}"
                                      materialDesign:HintAssist.Hint="工程站別(刷入工序條碼)"
                                      materialDesign:HintAssist.FloatingScale="0.55"
                                      Foreground="{DynamicResource MaterialDesignBody}"
                                      FontSize="28"
                                      FontWeight="Bold"
                                      Margin="0"
                                      Padding="0"
                                      VerticalAlignment="Bottom">
                                <ComboBox.Style>
                                    <Style TargetType="ComboBox"
                                           BasedOn="{StaticResource MaterialDesignFloatingHintComboBox}">
                                        <Setter Property="materialDesign:TextFieldAssist.UnderlineBrush"
                                                Value="Transparent" />
                                    </Style>
                                </ComboBox.Style>
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding BarCode}"
                                                       FontWeight="Bold"
                                                       Foreground="{DynamicResource MaterialDesignBody}" />
                                            <TextBlock Text=" - "
                                                       Foreground="{DynamicResource MaterialDesignBody}"
                                                       Opacity="0.7" />
                                            <TextBlock Text="{Binding Definition}"
                                                       Foreground="{DynamicResource MaterialDesignBody}"
                                                       Opacity="0.7" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </Border>
                    </Grid>

                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="500" />
                            <ColumnDefinition Width="150" />
                            
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Column="0"
                                Grid.Row="0"
                                CornerRadius="4"
                                Margin="0,0,16,0"
                                Padding="12,28,12,6">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderThickness"
                                            Value="1" />
                                    <Setter Property="BorderBrush"
                                            Value="#40FFFFFF" />
                                    <Setter Property="Background"
                                            Value="Transparent" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding FlashWorkTime}"
                                                     Value="True">
                                            <Setter Property="BorderBrush"
                                                    Value="{DynamicResource MaterialDesign.Brush.Primary.Light}" />
                                            <Setter Property="BorderThickness"
                                                    Value="2" />
                                            <Setter Property="Background">
                                                <Setter.Value>
                                                    <SolidColorBrush Color="{DynamicResource MaterialDesign.Color.Primary}"
                                                                     Opacity="0.15" />
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Grid Grid.Column="0"
                                      VerticalAlignment="Bottom">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.2*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="1*" />
                                    </Grid.ColumnDefinitions>

                                    <DatePicker Grid.Column="0"
                                                SelectedDate="{Binding WorkTime, UpdateSourceTrigger=PropertyChanged}"
                                                IsEnabled="{Binding IsWorkTimeManual}"
                                                materialDesign:HintAssist.Hint="作業日期"
                                                materialDesign:HintAssist.FloatingScale="0.55"
                                                materialDesign:TextFieldAssist.UnderlineBrush="Transparent"
                                                Foreground="{DynamicResource MaterialDesignBody}"
                                                FontSize="28"
                                                FontWeight="Bold"
                                                Margin="0"
                                                Padding="0"
                                                BorderThickness="0"
                                                Style="{StaticResource MaterialDesignFloatingHintDatePicker}"/>

                                    <materialDesign:TimePicker Grid.Column="2"
                                                               SelectedTime="{Binding WorkTime, UpdateSourceTrigger=PropertyChanged}"
                                                               IsEnabled="{Binding IsWorkTimeManual}"
                                                               Is24Hours="True"
                                                               WithSeconds="True"
                                                               materialDesign:HintAssist.Hint="時間 (24H)"
                                                               materialDesign:HintAssist.FloatingScale="0.55"
                                                               materialDesign:TextFieldAssist.UnderlineBrush="Transparent"
                                                               Foreground="{DynamicResource MaterialDesignBody}"
                                                               FontSize="28"
                                                               FontWeight="Bold"
                                                               Margin="0"
                                                               Padding="0"
                                                               BorderThickness="0" />
                                </Grid>

                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Bottom"
                                            Margin="12,0,0,4">
                                    <TextBlock Text="手動"
                                               VerticalAlignment="Center"
                                               Margin="0,0,4,0"
                                               Opacity="0.6"
                                               FontSize="14" />
                                    <ToggleButton IsChecked="{Binding IsWorkTimeManual}"
                                                  IsEnabled="{Binding CanEditWorkTimeToggle}"
                                                  Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                                  ToolTip="手動修改時間" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Column="1"
                                Grid.Row="0"
                                CornerRadius="4"
                                Margin="0,0,16,0"
                                Padding="12,12,12,6"
                                BorderThickness ="1"
                                BorderBrush="#40FFFFFF"
                                
                                IsEnabled="False"
                                >
                            <!--<Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderThickness"
                                            Value="1" />
                                    <Setter Property="BorderBrush"
                                            Value="#40FFFFFF" />
                                    <Setter Property="Background"
                                            Value="Transparent" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding FlashQuantity}"
                                                     Value="True">
                                            <Setter Property="BorderBrush"
                                                    Value="{DynamicResource MaterialDesign.Brush.Primary.Light}" />
                                            <Setter Property="BorderThickness"
                                                    Value="2" />
                                            <Setter Property="Background">
                                                <Setter.Value>
                                                    <SolidColorBrush Color="{DynamicResource MaterialDesign.Color.Primary}"
                                                                     Opacity="0.15" />
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>

                            <mah:NumericUpDown Value="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}"
                                               mah:TextBoxHelper.Watermark="數量 (Quantity)"
                                               mah:TextBoxHelper.UseFloatingWatermark="True"
                                               materialDesign:TextFieldAssist.UnderlineBrush="Transparent"
                                               Foreground="{DynamicResource MaterialDesignBody}"
                                               FontSize="28"
                                               FontWeight="Bold"
                                               Margin="0"
                                               Padding="0"
                                               Minimum="0"
                                               HideUpDownButtons="False"
                                               VerticalAlignment="Bottom"
                                               BorderThickness="0" />-->
                            <StackPanel VerticalAlignment="Bottom">
                                <TextBlock Text="數量 (Quantity)"
                                           FontSize="14"
                                           Opacity="0.6"
                                           Margin="0,0,0,2"
                                           />

                                <mah:NumericUpDown Value="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}"
                                                   Foreground="{DynamicResource MaterialDesignBody}"
                                                   FontSize="28"
                                                   FontWeight="Bold"
                                                   Margin="0"
                                                   Padding="0"
                                                   Minimum="0"
                                                   HideUpDownButtons="False"
                                                   BorderThickness="0"
                                                   materialDesign:TextFieldAssist.UnderlineBrush="Transparent" />
                            </StackPanel>

                        </Border>



                        <Border 
                                Grid.Column="0"
                                Grid.Row="1"
                                Grid.ColumnSpan="3"
                                CornerRadius="4"
                                Margin="0,16,0,0"
                                Padding="12,28,12,6">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderThickness"
                                            Value="1" />
                                    <Setter Property="BorderBrush"
                                            Value="#40FFFFFF" />
                                    <Setter Property="Background"
                                            Value="Transparent" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding FlashRemarks}"
                                                     Value="True">
                                            <Setter Property="BorderBrush"
                                                    Value="{DynamicResource MaterialDesign.Brush.Primary.Light}" />
                                            <Setter Property="BorderThickness"
                                                    Value="2" />
                                            <Setter Property="Background">
                                                <Setter.Value>
                                                    <SolidColorBrush Color="{DynamicResource MaterialDesign.Color.Primary}"
                                                                     Opacity="0.15" />
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBox Text="{Binding Remarks}"
                                     materialDesign:HintAssist.Hint="備註 (Remarks) 支援條碼疊加"
                                     materialDesign:HintAssist.FloatingScale="0.55"
                                     Foreground="{DynamicResource MaterialDesignBody}"
                                     FontSize="28"
                                     FontWeight="Bold"
                                     Margin="0"
                                     Padding="0"
                                     VerticalAlignment="Bottom">
                                <TextBox.Style>
                                    <Style TargetType="TextBox"
                                           BasedOn="{StaticResource MaterialDesignFloatingHintTextBox}">
                                        <Setter Property="materialDesign:TextFieldAssist.UnderlineBrush"
                                                Value="Transparent" />
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </Border>
                    </Grid>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Bottom"
                            Margin="16,0,0,4">
                    <Button Command="{Binding SaveDataCommand}"
                            Style="{StaticResource MaterialDesignRaisedDarkButton}"
                            Width="160"
                            Height="160"
                            Margin="0,0,12,0"
                            materialDesign:ButtonAssist.CornerRadius="12"
                            ToolTip="寫入/儲存資料">
                        <StackPanel>
                            <materialDesign:PackIcon Kind="ContentSaveEdit"
                                                     Width="116"
                                                     Height="116"
                                                     HorizontalAlignment="Center"
                                                     Foreground="{DynamicResource MaterialDesignBody}" />
                            <TextBlock Text="寫入"
                                       Margin="0,4,0,0"
                                       HorizontalAlignment="Center"
                                       FontWeight="Bold"
                                       FontSize="16"
                                       Foreground="{DynamicResource MaterialDesignBody}" />
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding ClearDataCommand}"
                            Style="{StaticResource MaterialDesignPaperDarkButton}"
                            Width="80"
                            Height="80"
                            Foreground="{DynamicResource MaterialDesignValidationErrorBrush}"
                            BorderBrush="{DynamicResource MaterialDesignValidationErrorBrush}"
                            materialDesign:ButtonAssist.CornerRadius="12"
                            ToolTip="清除重設畫面"
                            VerticalAlignment="Bottom">
                        <StackPanel>
                            <materialDesign:PackIcon Kind="EraserVariant"
                                                     Width="36"
                                                     Height="36"
                                                     HorizontalAlignment="Center" />
                            <TextBlock Text="清除"
                                       Margin="0,4,0,0"
                                       HorizontalAlignment="Center"
                                       FontWeight="Bold"
                                       FontSize="16" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="7*" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="3*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{DynamicResource MaterialDesignCardBackground}"
                    CornerRadius="8"
                    Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="實際作業歷程 (已執行)"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="{DynamicResource MaterialDesignBody}"
                               Opacity="0.7"
                               Margin="8,0,0,12" />

                    <DataGrid x:Name="DgActualWorkHistory" Grid.Row="1"
                              ItemsSource="{Binding ActualWorkHistory}"
                              CanUserDeleteRows="False"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              FontSize="18"
                              HeadersVisibility="Column"
                              Style="{StaticResource MaterialDesignDataGrid}">
                        <DataGrid.InputBindings>
                            <KeyBinding Key="Delete"
                                        Command="{Binding MarkAsDeletedCommand}"
                                        CommandParameter="{Binding ElementName=DgActualWorkHistory, Path=SelectedItem}" />
                        </DataGrid.InputBindings>
                        <DataGrid.Resources>
                            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
                            <Style x:Key="DeletedStrikethroughStyle"
                                   TargetType="TextBlock"
                                   BasedOn="{StaticResource MaterialDesignDataGridTextColumnStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Delete}"
                                                 Value="True">
                                        <Setter Property="TextDecorations"
                                                Value="Strikethrough" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.Resources>

                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow"
                                   BasedOn="{StaticResource MaterialDesignDataGridRow}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Delete}"
                                                 Value="True">
                                        <Setter Property="Background"
                                                Value="#1AEF5350" />
                                        <Setter Property="TextElement.Foreground"
                                                Value="#EF5350" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="作業時間"
                                                Binding="{Binding WorkTime, StringFormat='yyyy/MM/dd HH:mm:ss'}"
                                                Width="Auto"
                                                ElementStyle="{StaticResource DeletedStrikethroughStyle}" />

                            <DataGridTemplateColumn Header="工序站點"
                                                    Width="Auto">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="{Binding WorkStation}"
                                                       Style="{StaticResource DeletedStrikethroughStyle}"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center" />
                                            <Border Background="#E65100"
                                                    CornerRadius="2"
                                                    Padding="4,2"
                                                    Margin="8,0,0,0"
                                                    Visibility="{Binding IsExtra, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="非標準"
                                                           FontSize="14"
                                                           Foreground="White"
                                                           VerticalAlignment="Center" />
                                            </Border>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="作業機台"
                                                Binding="{Binding EqNo}"
                                                Width="Auto"
                                                ElementStyle="{StaticResource DeletedStrikethroughStyle}" />
                            <DataGridTextColumn Header="數量"
                                                Binding="{Binding Quantity}"
                                                Width="Auto"
                                                ElementStyle="{StaticResource DeletedStrikethroughStyle}" />
                            <DataGridTextColumn Header="作業員"
                                                Binding="{Binding User}"
                                                Width="Auto"
                                                ElementStyle="{StaticResource DeletedStrikethroughStyle}" />
                            <DataGridTextColumn Header="備註"
                                                Binding="{Binding Remarks}"
                                                Width="*"
                                                ElementStyle="{StaticResource DeletedStrikethroughStyle}" />

                            <DataGridTemplateColumn Header="狀態"
                                                    Width="Auto">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <materialDesign:PackIcon Kind="DeleteForever"
                                                                 Visibility="{Binding Delete, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                                 Foreground="#EF5350"
                                                                 Width="22"
                                                                 Height="22"
                                                                 HorizontalAlignment="Center"
                                                                 VerticalAlignment="Center" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Background="{DynamicResource MaterialDesignCardBackground}"
                    CornerRadius="8"
                    Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="標準作業工序 (SOP Flow)"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="{DynamicResource MaterialDesignBody}"
                               Opacity="0.7"
                               Margin="8,0,0,12" />

                    <DataGrid x:Name="DgStandardWorkFlow" Grid.Row="1"
                              ItemsSource="{Binding StandardWorkFlow}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              FontSize="18"
                              HeadersVisibility="Column"
                              Style="{StaticResource MaterialDesignDataGrid}">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow"
                                   BasedOn="{StaticResource MaterialDesignDataGridRow}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCompleted}"
                                                 Value="True">
                                        <Setter Property="Background"
                                                Value="#1B5E20" />
                                        <Setter Property="TextElement.Foreground"
                                                Value="White" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="NO"
                                                Binding="{Binding No}"
                                                Width="Auto"
                                                ElementStyle="{StaticResource MaterialDesignDataGridTextColumnStyle}" />

                            <DataGridTemplateColumn Header="跳站"
                                                    Width="Auto">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <materialDesign:PackIcon Kind="CheckAll"
                                                                 Visibility="{Binding CanPass, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                                 Width="20"
                                                                 Height="20"
                                                                 Opacity="0.7"
                                                                 HorizontalAlignment="Center"
                                                                 VerticalAlignment="Center" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="標準工序站點"
                                                Binding="{Binding WorkStation}"
                                                Width="*"
                                                ElementStyle="{StaticResource MaterialDesignDataGridTextColumnStyle}" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>