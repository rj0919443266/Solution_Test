<UserControl x:Class="WpfControlLibrary1.UserControl_LotDetail_FIR"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WpfControlLibrary1"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="900">

    <Grid>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="1.5*" />
                <RowDefinition Height="10" />
                <RowDefinition Height="3*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{DynamicResource MaterialDesignCardBackground}"
                    CornerRadius="8"
                    Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="歷次檢驗紀錄"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="{DynamicResource MaterialDesignBody}"
                               Opacity="0.7"
                               Margin="8,0,0,12" />

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding FirRecords}"
                              SelectedItem="{Binding SelectedFirRecord}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              FontSize="18"
                              Style="{StaticResource MaterialDesignDataGrid}">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="檢驗結果"
                                                    Width="Auto">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal"
                                                    VerticalAlignment="Center"
                                                    Margin="4,0">
                                            <TextBlock Text="["
                                                       Foreground="{DynamicResource MaterialDesignBody}"
                                                       Opacity="0.5"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,4,0" />

                                            <StackPanel Orientation="Horizontal"
                                                        VerticalAlignment="Center"
                                                        Margin="0,0,8,0">
                                                <StackPanel.Style>
                                                    <Style TargetType="StackPanel">
                                                        <Setter Property="Opacity"
                                                                Value="1" />
                                                        <Setter Property="TextElement.Foreground"
                                                                Value="#EF5350" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding AlarmCount}"
                                                                         Value="0">
                                                                <Setter Property="Opacity"
                                                                        Value="0.3" />
                                                                <Setter Property="TextElement.Foreground"
                                                                        Value="{DynamicResource MaterialDesignBody}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </StackPanel.Style>
                                                <materialDesign:PackIcon Kind="AlarmLight"
                                                                         Width="20"
                                                                         Height="20"
                                                                         VerticalAlignment="Center" />
                                                <TextBlock Text=":"
                                                           VerticalAlignment="Center"
                                                           Margin="2,0" />
                                                <TextBlock Text="{Binding AlarmCount}"
                                                           FontWeight="Bold"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>

                                            <StackPanel Orientation="Horizontal"
                                                        VerticalAlignment="Center"
                                                        Margin="0,0,8,0">
                                                <StackPanel.Style>
                                                    <Style TargetType="StackPanel">
                                                        <Setter Property="Opacity"
                                                                Value="1" />
                                                        <Setter Property="TextElement.Foreground"
                                                                Value="#FFD54F" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding WarningCount}"
                                                                         Value="0">
                                                                <Setter Property="Opacity"
                                                                        Value="0.3" />
                                                                <Setter Property="TextElement.Foreground"
                                                                        Value="{DynamicResource MaterialDesignBody}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </StackPanel.Style>
                                                <materialDesign:PackIcon Kind="AlertOutline"
                                                                         Width="20"
                                                                         Height="20"
                                                                         VerticalAlignment="Center" />
                                                <TextBlock Text=":"
                                                           VerticalAlignment="Center"
                                                           Margin="2,0" />
                                                <TextBlock Text="{Binding WarningCount}"
                                                           FontWeight="Bold"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>

                                            <StackPanel Orientation="Horizontal"
                                                        VerticalAlignment="Center"
                                                        Margin="0,0,8,0">
                                                <StackPanel.Style>
                                                    <Style TargetType="StackPanel">
                                                        <Setter Property="Opacity"
                                                                Value="1" />
                                                        <Setter Property="TextElement.Foreground"
                                                                Value="#66BB6A" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding NormalCount}"
                                                                         Value="0">
                                                                <Setter Property="Opacity"
                                                                        Value="0.3" />
                                                                <Setter Property="TextElement.Foreground"
                                                                        Value="{DynamicResource MaterialDesignBody}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </StackPanel.Style>
                                                <materialDesign:PackIcon Kind="CheckCircleOutline"
                                                                         Width="20"
                                                                         Height="20"
                                                                         VerticalAlignment="Center" />
                                                <TextBlock Text=":"
                                                           VerticalAlignment="Center"
                                                           Margin="2,0" />
                                                <TextBlock Text="{Binding NormalCount}"
                                                           FontWeight="Bold"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>

                                            <StackPanel Orientation="Horizontal"
                                                        VerticalAlignment="Center">
                                                <StackPanel.Style>
                                                    <Style TargetType="StackPanel">
                                                        <Setter Property="Opacity"
                                                                Value="1" />
                                                        <Setter Property="TextElement.Foreground"
                                                                Value="#BDBDBD" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding UnknownCount}"
                                                                         Value="0">
                                                                <Setter Property="Opacity"
                                                                        Value="0.3" />
                                                                <Setter Property="TextElement.Foreground"
                                                                        Value="{DynamicResource MaterialDesignBody}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </StackPanel.Style>
                                                <materialDesign:PackIcon Kind="HelpCircleOutline"
                                                                         Width="20"
                                                                         Height="20"
                                                                         VerticalAlignment="Center" />
                                                <TextBlock Text=":"
                                                           VerticalAlignment="Center"
                                                           Margin="2,0" />
                                                <TextBlock Text="{Binding UnknownCount}"
                                                           FontWeight="Bold"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>

                                            <TextBlock Text="]"
                                                       Foreground="{DynamicResource MaterialDesignBody}"
                                                       Opacity="0.5"
                                                       VerticalAlignment="Center"
                                                       Margin="4,0,0,0" />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="檢驗時間"
                                                Binding="{Binding CTime}"
                                                Width="Auto" />
                            <DataGridTextColumn Header="檢驗人員"
                                                Binding="{Binding User}"
                                                Width="Auto" />
                            <DataGridTextColumn Header="備註"
                                                Binding="{Binding Remarks}"
                                                Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Background="{DynamicResource MaterialDesignCardBackground}"
                    CornerRadius="8"
                    Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal"
                                Margin="8,0,0,12">
                        <TextBlock Text="量測數值 - "
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource MaterialDesignBody}"
                                   Opacity="0.7" />
                        <TextBlock Text="{Binding SelectedFirRecord.CTime}"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource MaterialDesignBody}"
                                   Opacity="0.7" />
                    </StackPanel>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding SelectedFirDataDetails}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              FontSize="18"
                              HeadersVisibility="Column"
                              GridLinesVisibility="All"
                              Style="{StaticResource MaterialDesignDataGrid}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="檢驗項目 (Name)"
                                                Binding="{Binding Name}"
                                                Width="Auto" />
                            <DataGridTextColumn Header="Target"
                                                Binding="{Binding Target}"
                                                Width="Auto" />
                            <DataGridTextColumn Header="Actual Data"
                                                Binding="{Binding ActualData}"
                                                Width="Auto" />

                            <DataGridTextColumn Header="Lower Limit"
                                                Binding="{Binding LowerLimit}"
                                                Width="Auto">
                                <DataGridTextColumn.CellStyle>
                                    <Style TargetType="DataGridCell"
                                           BasedOn="{StaticResource MaterialDesignDataGridCell}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Note}"
                                                         Value="Lower Alarm">
                                                <Setter Property="Background">
                                                    <Setter.Value>
                                                        <SolidColorBrush Color="#EF5350"
                                                                         Opacity="0.7" />
                                                    </Setter.Value>
                                                </Setter>
                                                <Setter Property="FontWeight"
                                                        Value="Bold" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGridTextColumn.CellStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Lower Warning"
                                                Binding="{Binding LowerWarning}"
                                                Width="Auto">
                                <DataGridTextColumn.CellStyle>
                                    <Style TargetType="DataGridCell"
                                           BasedOn="{StaticResource MaterialDesignDataGridCell}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Note}"
                                                         Value="Lower Warning">
                                                <Setter Property="Background">
                                                    <Setter.Value>
                                                        <SolidColorBrush Color="#FFD54F"
                                                                         Opacity="0.6" />
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGridTextColumn.CellStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Upper Warning"
                                                Binding="{Binding UpperWarning}"
                                                Width="Auto">
                                <DataGridTextColumn.CellStyle>
                                    <Style TargetType="DataGridCell"
                                           BasedOn="{StaticResource MaterialDesignDataGridCell}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Note}"
                                                         Value="Upper Warning">
                                                <Setter Property="Background">
                                                    <Setter.Value>
                                                        <SolidColorBrush Color="#FFD54F"
                                                                         Opacity="0.6" />
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGridTextColumn.CellStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Upper Limit"
                                                Binding="{Binding UpperLimit}"
                                                Width="Auto">
                                <DataGridTextColumn.CellStyle>
                                    <Style TargetType="DataGridCell"
                                           BasedOn="{StaticResource MaterialDesignDataGridCell}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Note}"
                                                         Value="Upper Alarm">
                                                <Setter Property="Background">
                                                    <Setter.Value>
                                                        <SolidColorBrush Color="#EF5350"
                                                                         Opacity="0.7" />
                                                    </Setter.Value>
                                                </Setter>
                                                <Setter Property="FontWeight"
                                                        Value="Bold" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGridTextColumn.CellStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Note"
                                                Binding="{Binding Note}"
                                                Width="*">
                                <DataGridTextColumn.CellStyle>
                                    <Style TargetType="DataGridCell"
                                           BasedOn="{StaticResource MaterialDesignDataGridCell}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding StatusLevel}"
                                                         Value="Warning">
                                                <Setter Property="Background">
                                                    <Setter.Value>
                                                        <SolidColorBrush Color="#FFD54F"
                                                                         Opacity="0.6" />
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding StatusLevel}"
                                                         Value="Alarm">
                                                <Setter Property="Background">
                                                    <Setter.Value>
                                                        <SolidColorBrush Color="#EF5350"
                                                                         Opacity="0.7" />
                                                    </Setter.Value>
                                                </Setter>
                                                <Setter Property="FontWeight"
                                                        Value="Bold" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGridTextColumn.CellStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <Grid Visibility="{Binding HasNoData, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border Background="{DynamicResource MaterialDesignPaper}"
                    Opacity="0.85" />
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center">
                <materialDesign:PackIcon Kind="DatabaseRemoveOutline"
                                         Width="80"
                                         Height="80"
                                         Foreground="{DynamicResource MaterialDesignBody}"
                                         Opacity="0.4"
                                         HorizontalAlignment="Center"
                                         Margin="0,0,0,16" />
                <TextBlock Text="目前無 FIR 檢驗紀錄"
                           FontSize="25"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource MaterialDesignBody}"
                           Opacity="0.7"
                           HorizontalAlignment="Center" />
                <TextBlock Text="此工單尚未進行檢驗"
                           FontSize="18"
                           Foreground="{DynamicResource MaterialDesignBody}"
                           Opacity="0.5"
                           Margin="0,8,0,0"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Grid>

        <Border Background="#80000000"
                Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
            <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                         Value="0"
                         IsIndeterminate="True"
                         Width="60"
                         Height="60" />
        </Border>
    </Grid>
</UserControl>