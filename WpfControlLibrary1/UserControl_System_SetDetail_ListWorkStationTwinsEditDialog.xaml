<UserControl x:Class="WpfControlLibrary1.UserControl_System_SetDetail_ListWorkStationTwinsEditDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Width="400"
             Padding="24">
    <StackPanel>
        <TextBlock Text="{Binding DialogTitle}"
                   FontSize="20"
                   FontWeight="Bold"
                   Margin="0,0,0,24" />

        <TextBox Text="{Binding WorkStationName, UpdateSourceTrigger=PropertyChanged}"
                 materialDesign:HintAssist.Hint="主工作站名稱 (PK)*"
                 Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                 IsEnabled="{Binding IsEditMode, Converter={StaticResource InvertBooleanConverter}}"
                 Margin="0,0,0,16" />
        <TextBox Text="{Binding WorkStationStart, UpdateSourceTrigger=PropertyChanged}"
                 materialDesign:HintAssist.Hint="開始站點對應名稱"
                 Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                 Margin="0,0,0,16" />
        <TextBox Text="{Binding WorkStationEnd, UpdateSourceTrigger=PropertyChanged}"
                 materialDesign:HintAssist.Hint="結束站點對應名稱"
                 Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                 Margin="0,0,0,24" />

        <Grid>
        </Grid>
    </StackPanel>
</UserControl>