<UserControl x:Class="WpfControlLibrary1.UserControl_LotDetail_WorkData"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WpfControlLibrary1"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800">
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="0,0,16,0">
            <Grid Margin="0,0,0,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="350" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto"
                                   MinHeight="350" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{DynamicResource MaterialDesignCardBackground}"
                        CornerRadius="8"
                        Padding="8">
                    <local:UserControl_Chart Series="{Binding DurationChartSeries}"
                                             XAxes="{Binding DurationXAxes}"
                                             YAxes="{Binding DurationYAxes}" />
                </Border>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="7*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="3*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="{DynamicResource MaterialDesignCardBackground}"
                            CornerRadius="8"
                            Padding="8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="作業資訊 (已執行歷程)"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource MaterialDesignBody}"
                                       Opacity="0.7"
                                       Margin="8,0,0,12" />

                            <DataGrid Grid.Row="1"
                                      ItemsSource="{Binding HistoryList}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      CanUserAddRows="False"
                                      FontSize="18"
                                      HeadersVisibility="Column"
                                      ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                      Style="{StaticResource MaterialDesignDataGrid}">

                                <DataGrid.Resources>
                                    <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
                                    <Style x:Key="DeletedStrikethroughStyle"
                                           TargetType="TextBlock"
                                           BasedOn="{StaticResource MaterialDesignDataGridTextColumnStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Delete}"
                                                         Value="True">
                                                <Setter Property="TextDecorations"
                                                        Value="Strikethrough" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.Resources>

                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow"
                                           BasedOn="{StaticResource MaterialDesignDataGridRow}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Delete}"
                                                         Value="True">
                                                <Setter Property="Background"
                                                        Value="#1AEF5350" />
                                                <Setter Property="TextElement.Foreground"
                                                        Value="#EF5350" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.RowStyle>

                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="作業時間"
                                                        Binding="{Binding ExeTime}"
                                                        Width="Auto"
                                                        ElementStyle="{StaticResource DeletedStrikethroughStyle}" />

                                    <DataGridTemplateColumn Header="工序站點"
                                                            Width="Auto">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal"
                                                            VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding StationName}"
                                                               Style="{StaticResource DeletedStrikethroughStyle}"
                                                               FontWeight="SemiBold"
                                                               VerticalAlignment="Center" />
                                                    <Border Background="#E65100"
                                                            CornerRadius="2"
                                                            Padding="4,2"
                                                            Margin="8,0,0,0"
                                                            Visibility="{Binding IsExtra, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                            VerticalAlignment="Center">
                                                        <TextBlock Text="非標準"
                                                                   FontSize="14"
                                                                   Foreground="White"
                                                                   VerticalAlignment="Center" />
                                                    </Border>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTextColumn Header="作業機台"
                                                        Binding="{Binding EqNo}"
                                                        Width="Auto"
                                                        ElementStyle="{StaticResource DeletedStrikethroughStyle}" />

                                    <DataGridTextColumn Header="作業員"
                                                        Binding="{Binding User}"
                                                        Width="Auto"
                                                        ElementStyle="{StaticResource DeletedStrikethroughStyle}" />

                                    <DataGridTextColumn Header="備註"
                                                        Binding="{Binding Remarks}"
                                                        Width="*"
                                                        ElementStyle="{StaticResource DeletedStrikethroughStyle}" />

                                    <DataGridTemplateColumn Header="狀態"
                                                            Width="Auto">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <materialDesign:PackIcon Kind="DeleteForever"
                                                                         Visibility="{Binding Delete, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                                         Foreground="#EF5350"
                                                                         Width="22"
                                                                         Height="22"
                                                                         HorizontalAlignment="Center"
                                                                         VerticalAlignment="Center" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2"
                            Background="{DynamicResource MaterialDesignCardBackground}"
                            CornerRadius="8"
                            Padding="8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="作業參考工序"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource MaterialDesignBody}"
                                       Opacity="0.7"
                                       Margin="8,0,0,12" />

                            <DataGrid Grid.Row="1"
                                      ItemsSource="{Binding RouteList}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      CanUserAddRows="False"
                                      FontSize="18"
                                      HeadersVisibility="Column"
                                      ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                      Style="{StaticResource MaterialDesignDataGrid}">
                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow"
                                           BasedOn="{StaticResource MaterialDesignDataGridRow}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsCompleted}"
                                                         Value="True">
                                                <Setter Property="Background"
                                                        Value="#1B5E20" />
                                                <Setter Property="TextElement.Foreground"
                                                        Value="White" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.RowStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="NO"
                                                        Binding="{Binding No}"
                                                        Width="Auto"
                                                        ElementStyle="{StaticResource MaterialDesignDataGridTextColumnStyle}" />
                                    <DataGridTemplateColumn Header="跳站"
                                                            Width="Auto">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <materialDesign:PackIcon Kind="CheckAll"
                                                                         Visibility="{Binding CanPass, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                                         Width="20"
                                                                         Height="20"
                                                                         Opacity="0.7"
                                                                         HorizontalAlignment="Center"
                                                                         VerticalAlignment="Center" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="標準工序站點"
                                                        Binding="{Binding StationName}"
                                                        Width="*"
                                                        ElementStyle="{StaticResource MaterialDesignDataGridTextColumnStyle}" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </ScrollViewer>
        <!--<Border Background="#80000000"
                Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
            <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                         Value="0"
                         IsIndeterminate="True"
                         Width="60"
                         Height="60" />
        </Border>-->
    </Grid>
</UserControl>