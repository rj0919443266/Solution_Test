<UserControl x:Class="WpfControlLibrary1.UserControl_System_SetDetail"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             
             xmlns:local="clr-namespace:WpfControlLibrary1"
             mc:Ignorable="d"
             d:DesignHeight="800"
             d:DesignWidth="1000"
             
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             
             >
    <Grid>
        <Grid Background="{DynamicResource MaterialDesignCardBackground}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0"
                  Width="100"
                  Background="{DynamicResource MaterialDesignPaper}">
                <ListBox x:Name="NavRail"
                         Background="Transparent"
                         BorderThickness="0"
                         SelectedIndex="{Binding SelectedTabIndex}"
                         Padding="0,16,0,0">

                    <ListBoxItem Style="{StaticResource MaterialDesign3.NavigationRailPrimaryListBoxItem}"
                                 materialDesign:NavigationRailAssist.IconSize="28"
                                 materialDesign:NavigationRailAssist.SelectedIcon="AccountHardHat"
                                 materialDesign:NavigationRailAssist.UnselectedIcon="AccountHardHat">
                        <TextBlock Text="生產者"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Margin="0,4,0,0"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center" />
                    </ListBoxItem>

                    <ListBoxItem Style="{StaticResource MaterialDesign3.NavigationRailPrimaryListBoxItem}"
                                 materialDesign:NavigationRailAssist.IconSize="28"
                                 materialDesign:NavigationRailAssist.SelectedIcon="RobotIndustrial"
                                 materialDesign:NavigationRailAssist.UnselectedIcon="RobotIndustrialOutline">
                        <TextBlock Text="機台"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Margin="0,4,0,0"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center" />
                    </ListBoxItem>

                    <ListBoxItem Style="{StaticResource MaterialDesign3.NavigationRailPrimaryListBoxItem}"
                                 materialDesign:NavigationRailAssist.IconSize="28"
                                 materialDesign:NavigationRailAssist.SelectedIcon="Domain"
                                 materialDesign:NavigationRailAssist.UnselectedIcon="Domain">
                        <TextBlock Text="製程部門"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Margin="0,4,0,0"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center" />
                    </ListBoxItem>

                    <ListBoxItem Style="{StaticResource MaterialDesign3.NavigationRailPrimaryListBoxItem}"
                                 materialDesign:NavigationRailAssist.IconSize="28"
                                 materialDesign:NavigationRailAssist.SelectedIcon="MapMarkerPath"
                                 materialDesign:NavigationRailAssist.UnselectedIcon="MapMarkerPath">
                        <TextBlock Text="工程站別"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Margin="0,4,0,0"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center" />
                    </ListBoxItem>

                    <ListBoxItem Style="{StaticResource MaterialDesign3.NavigationRailPrimaryListBoxItem}"
                                 materialDesign:NavigationRailAssist.IconSize="28"
                                 materialDesign:NavigationRailAssist.SelectedIcon="MapMarkerPath"
                                 materialDesign:NavigationRailAssist.UnselectedIcon="MapMarkerPath">
                        <TextBlock Text="工程站別關聯"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Margin="0,4,0,0"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   MinHeight="40" />
                    </ListBoxItem>

                    <ListBoxItem Style="{StaticResource MaterialDesign3.NavigationRailPrimaryListBoxItem}"
                                 materialDesign:NavigationRailAssist.IconSize="28"
                                 materialDesign:NavigationRailAssist.SelectedIcon="MapMarkerPath"
                                 materialDesign:NavigationRailAssist.UnselectedIcon="MapMarkerPath">
                        <TextBlock Text="製程異常別"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Margin="0,4,0,0"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center" />
                    </ListBoxItem>

                    <ListBoxItem Style="{StaticResource MaterialDesign3.NavigationRailPrimaryListBoxItem}"
                                 materialDesign:NavigationRailAssist.IconSize="28"
                                 materialDesign:NavigationRailAssist.SelectedIcon="MapMarkerPath"
                                 materialDesign:NavigationRailAssist.UnselectedIcon="MapMarkerPath">
                        <TextBlock Text="異常問題分類"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Margin="0,4,0,0"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   MinHeight="40" />
                       
                    </ListBoxItem>

                    <ListBoxItem Style="{StaticResource MaterialDesign3.NavigationRailPrimaryListBoxItem}"
                                 materialDesign:NavigationRailAssist.IconSize="28"
                                 materialDesign:NavigationRailAssist.SelectedIcon="MapMarkerPath"
                                 materialDesign:NavigationRailAssist.UnselectedIcon="MapMarkerPath">
                        <TextBlock Text="異常處理動作"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Margin="0,4,0,0"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   MinHeight="40" />
                    </ListBoxItem>

                    <ListBoxItem Style="{StaticResource MaterialDesign3.NavigationRailPrimaryListBoxItem}"
                                 materialDesign:NavigationRailAssist.IconSize="28"
                                 materialDesign:NavigationRailAssist.SelectedIcon="MapMarkerPath"
                                 materialDesign:NavigationRailAssist.UnselectedIcon="MapMarkerPath">
                        <TextBlock Text="數量"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Margin="0,4,0,0"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   MinHeight="40" />
                    </ListBoxItem>

                    <ListBoxItem Style="{StaticResource MaterialDesign3.NavigationRailPrimaryListBoxItem}"
                                 materialDesign:NavigationRailAssist.IconSize="28"
                                 materialDesign:NavigationRailAssist.SelectedIcon="MapMarkerPath"
                                 materialDesign:NavigationRailAssist.UnselectedIcon="MapMarkerPath">
                        <TextBlock Text="時間"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Margin="0,4,0,0"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   MinHeight="40" />
                    </ListBoxItem>

                    <ListBoxItem Style="{StaticResource MaterialDesign3.NavigationRailPrimaryListBoxItem}"
                                 materialDesign:NavigationRailAssist.IconSize="28"
                                 materialDesign:NavigationRailAssist.SelectedIcon="MapMarkerPath"
                                 materialDesign:NavigationRailAssist.UnselectedIcon="MapMarkerPath">
                        <TextBlock Text="備註"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Margin="0,4,0,0"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   MinHeight="40" />
                    </ListBoxItem>

                    
                   



                </ListBox>
            </Grid>

            <TabControl Grid.Column="1"
                        SelectedIndex="{Binding SelectedTabIndex}"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="16">
                <TabControl.ItemContainerStyle>
                    <Style TargetType="TabItem">
                        <Setter Property="Visibility"
                                Value="Collapsed" />
                    </Style>
                </TabControl.ItemContainerStyle>

                <TabItem>
                    <local:UserControl_System_SetDetail_ListUser DataContext="{Binding ListUserVM}" />
                </TabItem>

                <TabItem>
                    <local:UserControl_System_SetDetail_ListEqNo DataContext="{Binding ListEqNoVM}" />
                </TabItem>

                <TabItem>
                    <local:UserControl_System_SetDetail_process_department DataContext="{Binding ProcessDepartmentVM}" />
                </TabItem>

                <TabItem>
                    <local:UserControl_System_SetDetail_ListWorkStation DataContext="{Binding ListWorkStationVM}" />
                </TabItem>

                <TabItem>
                    <local:UserControl_System_SetDetail_ListWorkStationTwins DataContext="{Binding ListWorkStationTwinsVM}" />
                </TabItem>

                <TabItem>
                    <local:UserControl_System_SetDetail_ProcessAnomaly DataContext="{Binding ProcessAnomalyVM}" />
                </TabItem>

                <TabItem>
                    <local:UserControl_System_SetDetail_ProblemClassification DataContext="{Binding ProblemClassificationVM}" />
                </TabItem>

                <TabItem>
                    <local:UserControl_System_SetDetail_QualityAbnormalAction DataContext="{Binding QualityAbnormalActionVM}" />
                </TabItem>

                <TabItem>
                    <local:UserControl_System_SetDetail_InstructionSetNum DataContext="{Binding InstructionSetNumVM}" />
                </TabItem>

                <TabItem>
                    <local:UserControl_System_SetDetail_InstructionSetTime DataContext="{Binding InstructionSetTimeVM}" />
                </TabItem>

                <TabItem>
                    <local:UserControl_System_SetDetail_InstructionSetRemark DataContext="{Binding InstructionSetRemarkVM}" />
                </TabItem>


            </TabControl>
        </Grid>
    </Grid>
</UserControl>