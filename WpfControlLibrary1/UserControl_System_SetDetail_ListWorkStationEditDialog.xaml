<UserControl x:Class="WpfControlLibrary1.UserControl_System_SetDetail_ListWorkStationEditDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Width="400"
             Padding="24">
    <StackPanel>
        <TextBlock Text="{Binding DialogTitle}"
                   FontSize="20"
                   FontWeight="Bold"
                   Margin="0,0,0,24" />

        <TextBox Text="{Binding BarCode, UpdateSourceTrigger=PropertyChanged}"
                 materialDesign:HintAssist.Hint="工作站條碼 (PK)*"
                 Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                 IsEnabled="{Binding IsEditMode, Converter={StaticResource InvertBooleanConverter}}"
                 Margin="0,0,0,16" />
        <TextBox Text="{Binding Definition, UpdateSourceTrigger=PropertyChanged}"
                 materialDesign:HintAssist.Hint="工作站名稱*"
                 Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                 Margin="0,0,0,16" />
        <TextBox Text="{Binding Definition2, UpdateSourceTrigger=PropertyChanged}"
                 materialDesign:HintAssist.Hint="備用名稱"
                 Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                 Margin="0,0,0,16" />
        <TextBox Text="{Binding Department, UpdateSourceTrigger=PropertyChanged}"
                 materialDesign:HintAssist.Hint="所屬部門 (預設 AG)"
                 Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                 Margin="0,0,0,24" />

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button Command="{Binding CancelCommand}"
                    Content="取消"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Margin="0,0,8,0" />
            <Button Command="{Binding ConfirmSaveCommand}"
                    Content="儲存"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Grid.Column="1"
                    Margin="8,0,0,0" />
        </Grid>
    </StackPanel>
</UserControl>