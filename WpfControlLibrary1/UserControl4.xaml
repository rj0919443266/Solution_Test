<UserControl x:Class="WpfControlLibrary1.UserControl4"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WpfControlLibrary1"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="1000"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             xmlns:localVM="clr-namespace:WpfControlLibrary1.ViewModels">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0"
                    Orientation="Horizontal"
                    Margin="0,0,0,12">
            <TextBlock Text="即時產能看板"
                       FontSize="24"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource MaterialDesignBody}" />

            <Button Content="模擬機台過站資料 1"
                    Command="{Binding AddRandomDataCommand}"
                    Margin="20,0,0,0"
                    Padding="15,5" />

            <Button Content="模擬機台過站資料 2"
                    Command="{Binding AddRandomData_2Command}"
                    Margin="10,0,0,0"
                    Padding="15,5" />
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0"
                  Margin="0,0,8,0"
                  UseLayoutRounding="True"
                  SnapsToDevicePixels="True">

                <!--<Border Background="{DynamicResource MaterialDesignCardBackground}"
                        CornerRadius="8">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="15"
                                          Opacity="0.5"
                                          ShadowDepth="4"
                                          Color="Black" />
                    </Border.Effect>
                </Border>-->

                <Border CornerRadius="8"
                        Padding="16"
                        Background="Transparent">

                    <lvc:CartesianChart Series="{Binding MachineOutputSeries}"
                                        Background="{DynamicResource MaterialDesignPaper}"
                                        XAxes="{Binding XAxes}"
                                        YAxes="{Binding YAxes}"
                                        LegendPosition="Top"
                                        TooltipPosition="Hidden"
                                        LegendTextPaint="{Binding LegendTextPaint}"
                                        DataPointerDownCommand="{Binding ChartPointClickedCommand}" />
                </Border>
            </Grid>


            <Grid Grid.Column="1"
                  Margin="8,0,0,0"
                  UseLayoutRounding="True"
                  SnapsToDevicePixels="True">

                <Border Background="{DynamicResource MaterialDesignPaper}"
                        CornerRadius="8">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10"
                                          Opacity="0.1"
                                          ShadowDepth="2" />
                    </Border.Effect>
                </Border>

                <Border CornerRadius="8"
                        Padding="16"
                        Background="Transparent">
                    <lvc:CartesianChart Series="{Binding MachineOutputSeries_2}"
                                        Background="{DynamicResource MaterialDesignPaper}"
                                        XAxes="{Binding XAxes_2}"
                                        YAxes="{Binding YAxes_2}"
                                        LegendPosition="Top"
                                        TooltipPosition="Hidden"
                                        LegendTextPaint="{Binding LegendTextPaint}"
                                        DataPointerDownCommand="{Binding ChartPointClickedCommand}" />
                </Border>

            </Grid>
        </Grid>
    </Grid>
</UserControl>