<UserControl x:Class="WpfControlLibrary1.UserControl3"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WpfControlLibrary1"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid>
        <StackPanel>
            <TextBlock Text="工業控制看板  P3"
                       FontSize="22"
                       FontWeight="Bold"
                       Margin="0,0,0,24"
                       Foreground="{DynamicResource MaterialDesignPrimaryBrush}" />

            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <materialDesign:PackIcon Kind="RobotIndustrial"
                                         Width="28"
                                         Height="28"
                                         VerticalAlignment="Center"
                                         Margin="0,0,16,0"
                                         Foreground="{DynamicResource MaterialDesignBody}" />
                <TextBlock Grid.Column="1"
                           Text="{Binding MachineStatus}"
                           FontSize="18"
                           VerticalAlignment="Center" />
            </Grid>

            <Separator Style="{StaticResource MaterialDesignLightSeparator}"
                       Margin="0,8" />

            <Grid Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <materialDesign:PackIcon Kind="BarcodeScan"
                                         Width="28"
                                         Height="28"
                                         VerticalAlignment="Center"
                                         Margin="0,0,16,0"
                                         Foreground="{DynamicResource MaterialDesignBody}" />
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal">
                    <TextBlock Text="最新刷入條碼："
                               FontSize="18"
                               VerticalAlignment="Center" />
                    <TextBlock Text="{Binding LastScannedBarcode}"
                               FontSize="18"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource MaterialDesignSecondaryBrush}" />
                </StackPanel>
            </Grid>
        </StackPanel>

    </Grid>
</UserControl>
