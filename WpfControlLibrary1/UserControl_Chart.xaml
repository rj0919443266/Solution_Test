<UserControl x:Class="WpfControlLibrary1.UserControl_Chart"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             x:Name="Root">

    <Grid>
        <lvc:CartesianChart x:Name="GanttChartControl"
                            Background="Transparent"
                            Series="{Binding Series, ElementName=Root}"
                            XAxes="{Binding XAxes, ElementName=Root}"
                            YAxes="{Binding YAxes, ElementName=Root}"
                            TooltipPosition="Auto"
                           
                            
                            ZoomMode="Both"
                            MouseWheel="Chart_MouseWheel"
                            PreviewMouseRightButtonUp="Chart_PreviewMouseRightButtonUp"
                            PreviewMouseDoubleClick="Chart_PreviewMouseDoubleClick">
            <lvc:CartesianChart.ContextMenu>
                <ContextMenu x:Name="ChartMenu">

                    <MenuItem Header="複製圖片 (Copy Image)"
                              Click="MenuCopyImage_Click">
                        <MenuItem.Icon>
                            <materialDesign:PackIcon Kind="ContentCopy" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <MenuItem Header="儲存圖片 (Save Image As...)"
                              Click="MenuSaveImage_Click">
                        <MenuItem.Icon>
                            <materialDesign:PackIcon Kind="ContentSave" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <Separator x:Name="MenuSeparator" />

                    <MenuItem   x:Name="MenuItem_OpenNewWindow" 
                                Header="在新視窗開啟 (Open in New Window)"
                              Click="MenuOpenNewWindow_Click">
                        <MenuItem.Icon>
                            <materialDesign:PackIcon Kind="OpenInNew" />
                        </MenuItem.Icon>
                    </MenuItem>
                </ContextMenu>
            </lvc:CartesianChart.ContextMenu>

        </lvc:CartesianChart>
    </Grid>
</UserControl>