<UserControl x:Class="WpfControlLibrary1.UserControl_System_SetDetail_ListEqNoEditDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Width="450"
             Padding="24"
             Background="{DynamicResource MaterialDesignPaper}">
    <StackPanel>
        <TextBlock Text="{Binding DialogTitle}"
                   FontSize="20"
                   FontWeight="Bold"
                   Foreground="{DynamicResource MaterialDesignBody}"
                   Margin="0,0,0,24"
                   HorizontalAlignment="Center" />

        <TextBox Text="{Binding BarCode, UpdateSourceTrigger=PropertyChanged}"
                 materialDesign:HintAssist.Hint="機台條碼 / 編號 (主鍵)"
                 Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                 IsReadOnly="{Binding IsEditMode}"
                 FontSize="16"
                 Margin="0,0,0,16" />

        <TextBox Text="{Binding Definition, UpdateSourceTrigger=PropertyChanged}"
                 materialDesign:HintAssist.Hint="機台名稱"
                 Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                 FontSize="16"
                 Margin="0,0,0,16" />

        <ComboBox ItemsSource="{Binding DepartmentList}"
                  DisplayMemberPath="Definition"
                  SelectedValuePath="Definition"
                  SelectedValue="{Binding Department, UpdateSourceTrigger=PropertyChanged}"
                  materialDesign:HintAssist.Hint="所屬部門"
                  Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                  FontSize="16"
                  Margin="0,0,0,32" />

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button Command="{Binding CancelCommand}"
                    Content="取消"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Height="40"
                    FontSize="14"
                    Margin="0,0,8,0" />
            <Button Command="{Binding ConfirmSaveCommand}"
                    Content="儲存變更"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Grid.Column="1"
                    Height="40"
                    FontSize="14"
                    Margin="8,0,0,0" />
        </Grid>
    </StackPanel>
</UserControl>