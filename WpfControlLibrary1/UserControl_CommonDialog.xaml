<UserControl x:Class="WpfControlLibrary1.UserControl_CommonDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Width="450"
             Background="{DynamicResource MaterialDesignPaper}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal"
                    Grid.Row="0"
                    Margin="0,0,0,16">
            <materialDesign:PackIcon Kind="{Binding IconKind}"
                                     Foreground="{Binding IconColor}"
                                     Width="36"
                                     Height="36"
                                     VerticalAlignment="Center"
                                     Margin="0,0,12,0" />
            <TextBlock Text="{Binding Title}"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="{DynamicResource MaterialDesignBody}"
                       VerticalAlignment="Center" />
        </StackPanel>

        <TextBlock Grid.Row="1"
                   Text="{Binding Message}"
                   FontSize="16"
                   TextWrapping="Wrap"
                   Foreground="{DynamicResource MaterialDesignBody}"
                   Opacity="0.8"
                   Margin="0,0,0,32"
                   MinHeight="60" />

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Command="{Binding CancelCommand}"
                    Content="{Binding CancelText}"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Visibility="{Binding ShowCancelButton, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Margin="0,0,12,0"
                    Height="40"
                    FontSize="15"
                    MinWidth="100" />

            <Button Command="{Binding ConfirmCommand}"
                    Content="{Binding ConfirmText}"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Height="40"
                    FontSize="15"
                    MinWidth="100" />
        </StackPanel>
    </Grid>
</UserControl>