<UserControl x:Class="WpfControlLibrary1.UserControl_SystemComfig"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WpfControlLibrary1"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="30">
        <StackPanel MaxWidth="550"
                    HorizontalAlignment="Left">

            <TextBlock Text="系統參數參數設定"
                       FontSize="22"
                       FontWeight="Bold"
                       Margin="0,0,0,24"
                       Foreground="{DynamicResource MaterialDesignPrimaryBrush}" />

            <TextBlock Text="PHP Server API 遠端網址"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Margin="0,0,0,8"
                       Foreground="{DynamicResource MaterialDesignBody}" />
            <TextBox Text="{Binding PhpServerUrl, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource MaterialDesignFilledTextBox}"
                     materialDesign:HintAssist.Hint="例如: 192.168.1.100"
                     Margin="0,0,0,24" />

            <TextBlock Text="預設條碼槍 COM 埠 (開機時自動連線目標)"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Margin="0,0,0,8"
                       Foreground="{DynamicResource MaterialDesignBody}" />
            <ComboBox ItemsSource="{Binding AvailablePorts}"
                      SelectedItem="{Binding BarcodeComPort}"
                      Style="{StaticResource MaterialDesignFilledComboBox}"
                      Margin="0,0,0,32">
                <b:Interaction.Triggers>
                    <b:EventTrigger EventName="DropDownOpened">
                        <b:InvokeCommandAction Command="{Binding RefreshAvailablePortsCommand}" />
                    </b:EventTrigger>
                </b:Interaction.Triggers>
            </ComboBox>

            <Separator Background="{DynamicResource MaterialDesignDivider}"
                       Margin="0,0,0,24" />

            <Button Command="{Binding SaveConfigCommand}"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Width="150"
                    HorizontalAlignment="Left"
                    Height="40">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="ContentSave"
                                             Width="20"
                                             Height="20"
                                             VerticalAlignment="Center"
                                             Margin="0,0,8,0" />
                    <TextBlock Text="儲存設定"
                               VerticalAlignment="Center"
                               FontSize="14" />
                </StackPanel>
            </Button>

        </StackPanel>
    </Grid>
</UserControl>
