<UserControl x:Class="WpfControlLibrary1.UserControl_LotDetail_Quality_Nonconformity_Report"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WpfControlLibrary1"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="800"
             d:DesignWidth="1200">
    <Grid>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="1.5*" />
                <RowDefinition Height="5" />
                <RowDefinition Height="3*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{DynamicResource MaterialDesignCardBackground}"
                    CornerRadius="8"
                    Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="歷次異常通知紀錄 (點擊選取可於下方查看工序變更明細)"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="{DynamicResource MaterialDesignBody}"
                               Opacity="0.7"
                               Margin="8,0,0,12" />

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding NoticeRecords}"
                              SelectedItem="{Binding SelectedNotice}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              FontSize="18"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                              Style="{StaticResource MaterialDesignDataGrid}">
                        <DataGrid.Resources>
                            <Style TargetType="TextBlock"
                                   BasedOn="{StaticResource MaterialDesignDataGridTextColumnStyle}">
                                <Setter Property="TextWrapping"
                                        Value="Wrap" />
                                <Setter Property="Margin"
                                        Value="4,8" />
                            </Style>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="發生時間"
                                                Binding="{Binding CTime, StringFormat={}{0:MM/dd HH:mm}}"
                                                Width="Auto" />
                            <DataGridTextColumn Header="發現單位"
                                                Binding="{Binding ProcessDepartment}"
                                                Width="Auto" />
                            <DataGridTextColumn Header="異常階段"
                                                Binding="{Binding ProcessAnomaly}"
                                                Width="Auto"
                                                Foreground="OrangeRed"
                                                FontWeight="SemiBold" />
                            <DataGridTextColumn Header="問題分類"
                                                Binding="{Binding ProblemClassification}"
                                                Width="Auto" />
                            <DataGridTextColumn Header="問題描述"
                                                Binding="{Binding ProblemClassificationTxt}"
                                                Width="200" />
                            <DataGridTextColumn Header="真因分析 (Root Cause)"
                                                Binding="{Binding RootCauseAnalysisTxt}"
                                                Width="250"
                                                Foreground="#FFD54F" />
                            <DataGridTextColumn Header="處置方式"
                                                Binding="{Binding QualityAbnormalAction}"
                                                Width="Auto"
                                                Foreground="LimeGreen"
                                                FontWeight="Bold" />
                            <DataGridTextColumn Header="處置說明"
                                                Binding="{Binding QualityAbnormalActionTxt}"
                                                Width="200" />
                            <DataGridTextColumn Header="OP"
                                                Binding="{Binding Op}"
                                                Width="Auto" />
                            <DataGridTextColumn Header="QC"
                                                Binding="{Binding Qc}"
                                                Width="Auto" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="5" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="{DynamicResource MaterialDesignCardBackground}"
                        CornerRadius="8"
                        Padding="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="原製程工序 (變更前)"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource MaterialDesignBody}"
                                   Opacity="0.7"
                                   Margin="8,0,0,12" />

                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding OldStationList}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  FontSize="18"
                                  HeadersVisibility="Column"
                                  Style="{StaticResource MaterialDesignDataGrid}">
                            <DataGrid.Resources>
                                <Style x:Key="RemovedStrikethroughStyle"
                                       TargetType="TextBlock"
                                       BasedOn="{StaticResource MaterialDesignDataGridTextColumnStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DiffStatus}"
                                                     Value="Removed">
                                            <Setter Property="TextDecorations"
                                                    Value="Strikethrough" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.Resources>
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow"
                                       BasedOn="{StaticResource MaterialDesignDataGridRow}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DiffStatus}"
                                                     Value="Removed">
                                            <Setter Property="Background"
                                                    Value="#1AEF5350" />
                                            <Setter Property="TextElement.Foreground"
                                                    Value="#EF5350" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="NO"
                                                    Binding="{Binding No}"
                                                    Width="Auto"
                                                    ElementStyle="{StaticResource RemovedStrikethroughStyle}" />
                                <DataGridTemplateColumn Header="跳站"
                                                        Width="Auto">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <materialDesign:PackIcon Kind="CheckAll"
                                                                     Visibility="{Binding CanPass, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                                     Width="20"
                                                                     Height="20"
                                                                     Opacity="0.7"
                                                                     VerticalAlignment="Center"
                                                                     HorizontalAlignment="Center" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="工序站點"
                                                    Binding="{Binding WorkStation}"
                                                    Width="*"
                                                    ElementStyle="{StaticResource RemovedStrikethroughStyle}" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <Border Grid.Column="2"
                        Background="{DynamicResource MaterialDesignCardBackground}"
                        CornerRadius="8"
                        Padding="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel Orientation="Horizontal"
                                    Margin="8,0,0,12">
                            <TextBlock Text="新製程工序 (變更後) - "
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource MaterialDesignBody}"
                                       Opacity="0.7" />
                            <TextBlock Text="{Binding SelectedNotice.CTime}"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Opacity="0.7"
                                       Foreground="{DynamicResource MaterialDesignBody}" />
                        </StackPanel>

                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding NewStationList}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  FontSize="18"
                                  HeadersVisibility="Column"
                                  Style="{StaticResource MaterialDesignDataGrid}">
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow"
                                       BasedOn="{StaticResource MaterialDesignDataGridRow}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DiffStatus}"
                                                     Value="Added">
                                            <Setter Property="Background"
                                                    Value="#1A66BB6A" />
                                            <Setter Property="TextElement.Foreground"
                                                    Value="#66BB6A" />
                                            <Setter Property="FontWeight"
                                                    Value="Bold" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="NO"
                                                    Binding="{Binding No}"
                                                    Width="Auto" />
                                <DataGridTemplateColumn Header="跳站"
                                                        Width="Auto">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <materialDesign:PackIcon Kind="CheckAll"
                                                                     Visibility="{Binding CanPass, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                                     Width="20"
                                                                     Height="20"
                                                                     Opacity="0.7"
                                                                     VerticalAlignment="Center"
                                                                     HorizontalAlignment="Center" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="工序站點"
                                                    Binding="{Binding WorkStation}"
                                                    Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Grid Visibility="{Binding HasNoData, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border Background="{DynamicResource MaterialDesignPaper}"
                    Opacity="0.85" />
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center">
                <materialDesign:PackIcon Kind="ClipboardRemoveOutline"
                                         Width="80"
                                         Height="80"
                                         Foreground="{DynamicResource MaterialDesignBody}"
                                         Opacity="0.4"
                                         HorizontalAlignment="Center"
                                         Margin="0,0,0,16" />
                <TextBlock Text="目前無品質異常紀錄"
                           FontSize="25"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource MaterialDesignBody}"
                           Opacity="0.7"
                           HorizontalAlignment="Center" />
                <TextBlock Text="此工單生產過程中無開立任何品質異常單"
                           FontSize="18"
                           Foreground="{DynamicResource MaterialDesignBody}"
                           Opacity="0.5"
                           Margin="0,8,0,0"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Grid>

        <Border Background="#80000000"
                Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
            <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                         Value="0"
                         IsIndeterminate="True"
                         Width="60"
                         Height="60" />
        </Border>
    </Grid>
</UserControl>