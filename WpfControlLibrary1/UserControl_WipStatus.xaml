<UserControl x:Class="WpfControlLibrary1.UserControl_WipStatus"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WpfControlLibrary1"
             mc:Ignorable="d"
             d:DesignHeight="800"
             d:DesignWidth="1000"
             xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             xmlns:localVM="clr-namespace:WpfControlLibrary1.ViewModels">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="350" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource MaterialDesignCardBackground}"
                CornerRadius="8"
                Margin="0,0,0,12">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10"
                                  Opacity="0.1"
                                  ShadowDepth="2" />
            </Border.Effect>

            <WrapPanel Orientation="Horizontal"
                       Margin="16"
                       VerticalAlignment="Center">
                <materialDesign:PackIcon Kind="Magnify"
                                         Width="24"
                                         Height="24"
                                         VerticalAlignment="Bottom"
                                         Margin="0,0,8,12"
                                         Foreground="{DynamicResource MaterialDesignBody}" />
                <TextBlock Text="過站明細查詢"
                           FontSize="25"
                           FontWeight="Bold"
                           VerticalAlignment="Bottom"
                           Foreground="{DynamicResource MaterialDesignBody}"
                           Margin="0,0,24,6" />

                <DatePicker SelectedDate="{Binding SearchStartDate}"
                            materialDesign:HintAssist.Hint="開始日期"
                            FontSize="18"
                            Width="140"
                            Margin="0,4,16,4"
                            Padding="0,5,0,0"
                            VerticalAlignment="Bottom"
                            Style="{StaticResource MaterialDesignFloatingHintDatePicker}" />
                <DatePicker SelectedDate="{Binding SearchEndDate}"
                            materialDesign:HintAssist.Hint="結束日期"
                            FontSize="18"
                            Width="140"
                            Margin="0,4,16,4"
                            Padding="0,5,0,0"
                            VerticalAlignment="Bottom"
                            Style="{StaticResource MaterialDesignFloatingHintDatePicker}" />
                <TextBox Text="{Binding SearchLotNo}"
                         materialDesign:HintAssist.Hint="工單號 (Lot No)"
                         FontSize="18"
                         Width="180"
                         Margin="0,4,16,4"
                         Padding="0,6,0,1"
                         VerticalAlignment="Bottom"
                         Style="{StaticResource MaterialDesignFloatingHintTextBox}" />
                <TextBox Text="{Binding SearchParentLotNo}"
                         materialDesign:HintAssist.Hint="柱號 (Parent Lot)"
                         FontSize="18"
                         Width="160"
                         Margin="0,4,16,4"
                         Padding="0,6,0,1"
                         VerticalAlignment="Bottom"
                         Style="{StaticResource MaterialDesignFloatingHintTextBox}" />
                <ComboBox IsEditable="True"
                          Text="{Binding SearchProductName}"
                          ItemsSource="{Binding ProductNameList}"
                          materialDesign:HintAssist.Hint="產品名稱"
                          FontSize="18"
                          Width="180"
                          Margin="0,4,16,4"
                          VerticalAlignment="Bottom"
                          Style="{StaticResource MaterialDesignFloatingHintComboBox}" />

                <Button Command="{Binding SearchWipCommand}"
                        Style="{StaticResource MaterialDesignRaisedDarkButton}"
                        FontSize="20"
                        Height="50"
                        Padding="32,0"
                        Margin="16,4,0,4"
                        VerticalAlignment="Bottom">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Search"
                                                 Width="28"
                                                 Height="28"
                                                 VerticalAlignment="Center"
                                                 Margin="0,0,8,0" />
                        <TextBlock Text="執行查詢"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <StackPanel Orientation="Horizontal"
                            Margin="24,4,0,12"
                            VerticalAlignment="Bottom">
                    <TextBlock Text="包含完成"
                               FontSize="18"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0"
                               Foreground="{DynamicResource MaterialDesignBody}" />
                    <ToggleButton IsChecked="{Binding IncludeCompleted}"
                                  Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                  VerticalAlignment="Center"
                                  ToolTip="開啟後將顯示已走完所有必做站點的工單" />
                </StackPanel>
            </WrapPanel>
        </Border>

        <Border Grid.Row="1"
                Background="{DynamicResource MaterialDesignCardBackground}"
                CornerRadius="8"
                Margin="0,0,0,12"
                Padding="16">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10"
                                  Opacity="0.1"
                                  ShadowDepth="2" />
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0"
                      Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock Text="當前站點"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"
                                   Foreground="{DynamicResource MaterialDesignBody}" />
                        <ToggleButton IsChecked="{Binding IsGroupedByNextStation}"
                                      Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                      ToolTip="切換 X 軸分組依據" />
                        <TextBlock Text="下一站"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Margin="8,0,0,0"
                                   Foreground="{DynamicResource MaterialDesignBody}" />
                    </StackPanel>
                </Grid>

                <local:UserControl_Chart Grid.Row="1"
                                         Background="{DynamicResource MaterialDesignPaper}"
                                         Series="{Binding StationChartSeries}"
                                         XAxes="{Binding StationXAxes}"
                                         YAxes="{Binding StationYAxes}"
                                         ChartDoubleClickCommand="{Binding ChartDoubleClickCommand}"/>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Background="{DynamicResource MaterialDesignCardBackground}"
                CornerRadius="8"
                Padding="16">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10"
                                  Opacity="0.1"
                                  ShadowDepth="2" />
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0"
                            Orientation="Horizontal"
                            Margin="0,0,0,8"
                            VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="FormatListNumbered"
                                             Width="20"
                                             Height="20"
                                             Margin="0,0,8,0"
                                             Foreground="{DynamicResource MaterialDesignBody}" />
                    <TextBlock Text="{Binding TotalCountMessage}"
                               FontSize="16"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground"
                                        Value="{DynamicResource MaterialDesignBody}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLimitReached}"
                                                 Value="True">
                                        <Setter Property="Foreground"
                                                Value="OrangeRed" />
                                        <Setter Property="ToolTip"
                                                Value="已達查詢上限！如果找不到你要的工單，請縮小日期範圍或增加搜尋條件。" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <DataGrid Grid.Row="1"
                          SelectedItem="{Binding SelectedWipItem}"
                          ItemsSource="{Binding WipDataList}"
                          FontSize="18"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          HeadersVisibility="All"
                          Style="{StaticResource MaterialDesignDataGrid}"
                          local:DataGridHelper.EnableScrollIntoView="True">
                    <b:Interaction.Triggers>
                        <b:EventTrigger EventName="MouseDoubleClick">
                            <b:InvokeCommandAction Command="{Binding RowDoubleClickCommand}" />
                        </b:EventTrigger>
                    </b:Interaction.Triggers>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="工單號 (Lot No)"
                                            Binding="{Binding Lot_no}"
                                            Width="1.5*" />

                        <DataGridTextColumn Header="產品名稱"
                                            Binding="{Binding Product_name}"
                                            Width="1.5*" />

                        <DataGridTextColumn Header="當前站點"
                                            Binding="{Binding current_station}"
                                            Width="2*" />

                        <DataGridTextColumn Header="下一站"
                                            Binding="{Binding next_station}"
                                            Width="2*" />

                        <DataGridTextColumn Header="最後更新時間"
                                            Binding="{Binding last_update_time}"
                                            Width="1.5*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment"
                                            Value="Center" />
                                    <Setter Property="VerticalAlignment"
                                            Value="Center" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTemplateColumn Header="明細"
                                                Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                            ToolTip="查看工序歷程與明細"
                                            Height="30"
                                            Padding="8,0"
                                            Command="{Binding DataContext.ShowDetailCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}">
                                        <materialDesign:PackIcon Kind="FormatListText"
                                                                 Width="18"
                                                                 Height="18" />
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

    </Grid>
</UserControl>

