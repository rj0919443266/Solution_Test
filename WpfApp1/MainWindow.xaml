<mah:MetroWindow x:Class="WpfApp1.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
                 xmlns:views="clr-namespace:WpfControlLibrary1;assembly=WpfControlLibrary1"
                 xmlns:viewmodels_lib="clr-namespace:WpfControlLibrary1.ViewModels;assembly=WpfControlLibrary1"
                 xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
                 Title="WorkPage"
                 Height="500"
                 Width="900"
                 WindowStartupLocation="CenterScreen"
                 Background="{DynamicResource MaterialDesignPaper}"
                 TextElement.Foreground="{DynamicResource MaterialDesignBody}"
                 
                 WindowTitleBrush="{DynamicResource MaterialDesignPaper}"
                 NonActiveWindowTitleBrush="{DynamicResource MaterialDesignPaper}"
                 TitleForeground="{DynamicResource MaterialDesignBody}"
                 
                 WindowButtonCommandsOverlayBehavior="Never"
                 
                 TitleCharacterCasing="Normal"
                 GlowBrush="{DynamicResource PrimaryHueMidBrush}"
                 TitleBarHeight="50"
                 SaveWindowPosition="True"
                 ShowCloseButton="False"
                 >
    <!--分頁資源-->
    <Window.Resources>
        <DataTemplate DataType="{x:Type viewmodels_lib:UserControl1ViewModel}">
            <views:UserControl1 />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels_lib:UserControl2ViewModel}">
            <views:UserControl2 />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels_lib:UserControl3ViewModel}">
            <views:UserControl3 />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels_lib:MVVM_SystemConfig}">
            <views:UserControl_SystemComfig/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels_lib:VM_Login}">
            <views:UserControl_Login />
        </DataTemplate>
    </Window.Resources>
    
    <!--抬頭設計樣板-->
    <mah:MetroWindow.TitleTemplate>
        <DataTemplate>
            <StackPanel Orientation="Vertical"
                        VerticalAlignment="Center"
                        Margin="10,0,0,0">
                <TextBlock Text="{Binding}"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource MaterialDesignBody}" />

                <TextBlock Text="{Binding DataContext.FileVersion, RelativeSource={RelativeSource AncestorType=mah:MetroWindow}}"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="Gray" />
            </StackPanel>
        </DataTemplate>
    </mah:MetroWindow.TitleTemplate>
    <!--左抬頭 按鈕與版本顯示-->
    <mah:MetroWindow.LeftWindowCommands>
        <mah:WindowCommands>
            <ToggleButton Style="{StaticResource MaterialDesignHamburgerToggleButton}"
                          IsChecked="{Binding IsLeftDrawerOpen, ElementName=MainDrawerHost}"
                          Margin="10,0,10,0" />
            <!--<TextBlock Text="{Binding FileVersion}"
                       VerticalAlignment="Center"
                       Margin="10,0"
                       Foreground="Gray" />-->
        </mah:WindowCommands>
    </mah:MetroWindow.LeftWindowCommands>
    <!--右抬頭 顯示-->
    <mah:MetroWindow.RightWindowCommands>
        <mah:WindowCommands>
            <StackPanel Orientation="Horizontal"
                        Margin="10,0">
                <materialDesign:PackIcon Kind="Account"
                                         VerticalAlignment="Center"
                                         Margin="0,0,5,0" />
                <TextBlock Text="{Binding User_ID}"
                           FontWeight="Bold"
                           VerticalAlignment="Center" />
                <Border Width="1"
                        Height="16"
                        Background="{DynamicResource MaterialDesignDivider}"
                        Margin="10,0"
                        VerticalAlignment="Center" />
                <TextBlock Text="{Binding User_Name}"
                           FontWeight="Bold"
                           VerticalAlignment="Center" />
            </StackPanel>

            <StackPanel Orientation="Horizontal"
                        Margin="10,0">
                <materialDesign:PackIcon Kind="ServerNetwork"
                                         VerticalAlignment="Center"
                                         Margin="0,0,5,0" />
                <TextBlock Text="Server: "
                           VerticalAlignment="Center" />
                <TextBlock Text="{Binding PhpConnectionStatus}"
                           FontWeight="Bold"
                           VerticalAlignment="Center" />
            </StackPanel>

            <StackPanel Orientation="Horizontal"
                        Margin="10,0">
                <materialDesign:PackIcon Kind="BarcodeScan"
                                         VerticalAlignment="Center"
                                         Margin="0,0,5,0" />
                <TextBlock Text="掃碼槍: "
                           VerticalAlignment="Center" />
                
                <!--<ComboBox ItemsSource="{Binding AvailablePorts}"
                          SelectedItem="{Binding SelectedPort}"
                          Margin="16,4"
                          Style="{StaticResource MaterialDesignComboBox}">
                    <b:Interaction.Triggers>
                        <b:EventTrigger EventName="DropDownOpened">
                            <b:InvokeCommandAction Command="{Binding RefreshAvailablePorts}" />
                        </b:EventTrigger>
                    </b:Interaction.Triggers>
                </ComboBox>-->

                <TextBlock Text="{Binding ScannerStatus}"
                           FontWeight="Bold"
                           VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground"
                                    Value="{DynamicResource MaterialDesignBody}" />

                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ConnectionState}"
                                             Value="Connected">
                                    <Setter Property="Foreground"
                                            Value="LimeGreen" />
                                </DataTrigger>

                                <DataTrigger Binding="{Binding ConnectionState}"
                                             Value="Failed">
                                    <Setter Property="Foreground"
                                            Value="Red" />
                                </DataTrigger>

                                <DataTrigger Binding="{Binding ConnectionState}"
                                             Value="Disconnected">
                                    <Setter Property="Foreground"
                                            Value="OrangeRed" />
                                </DataTrigger>

                                <DataTrigger Binding="{Binding ConnectionState}"
                                             Value="Gray" />
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <Button Command="{Binding ReconnectCommand}"
                        Style="{StaticResource MaterialDesignIconButton}"
                        Width="24"
                        Height="24"
                        Padding="0"
                        Margin="8,0,0,0"
                        VerticalAlignment="Center"
                        ToolTip="重新連線掃描槍">
                    <materialDesign:PackIcon Kind="Refresh"
                                             Width="16"
                                             Height="16"
                                             Foreground="{DynamicResource MaterialDesignBody}" />
                </Button>
            </StackPanel>

            <materialDesign:PopupBox PlacementMode="BottomAndAlignRightEdges"
                                     StaysOpen="False"
                                     Margin="10,0,10,0"
                                     VerticalAlignment="Center">
                <StackPanel Width="180">
                   
                    <Separator Background="{DynamicResource MaterialDesignDivider}" />

                    <Button Style="{StaticResource MaterialDesignFlatButton}"
                            HorizontalContentAlignment="Left"
                            Command="{Binding LoginCommand}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Account"
                                                     Width="18"
                                                     Height="18"
                                                     VerticalAlignment="Center"
                                                     Margin="0,0,12,0" />
                            <TextBlock Text="登入/登出"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Separator Background="{DynamicResource MaterialDesignDivider}" />

                    <Button Style="{StaticResource MaterialDesignFlatButton}"
                            HorizontalContentAlignment="Left"
                            Foreground="DeepPink"
                            FontWeight="Bold"
                            Click="CloseButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Power"
                                                     Width="18"
                                                     Height="18"
                                                     VerticalAlignment="Center"
                                                     Margin="0,0,12,0" />
                            <TextBlock Text="關閉程式"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </materialDesign:PopupBox>
        </mah:WindowCommands>
    </mah:MetroWindow.RightWindowCommands>
    <materialDesign:DialogHost Identifier="RootDialog" DialogTheme="Inherit">
        <materialDesign:DrawerHost x:Name="MainDrawerHost">
            
        <materialDesign:DrawerHost.LeftDrawerContent>
            <Grid Width="280"
                  Background="{DynamicResource MaterialDesignPaper}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="功能導覽"
                           FontSize="18"
                           FontWeight="Bold"
                           Margin="16,24,16,16" />

                <TreeView Grid.Row="1"
                          ItemsSource="{Binding MenuItems}"
                          Style="{StaticResource MaterialDesignTreeView}"
                          SelectedItemChanged="TreeView_SelectedItemChanged">

                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding SubItems}">
                            <StackPanel Orientation="Horizontal"
                                        Margin="8,4">
                                <materialDesign:PackIcon Kind="{Binding Icon}"
                                                         Width="24"
                                                         Height="24"
                                                         VerticalAlignment="Center" />
                                <TextBlock Text="{Binding Title}"
                                           Margin="16,0,0,0"
                                           VerticalAlignment="Center"
                                           FontSize="15" />
                            </StackPanel>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>

                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem"
                               BasedOn="{StaticResource MaterialDesignTreeViewItem}">
                            <Setter Property="Padding"
                                    Value="8" />
                        </Style>
                    </TreeView.ItemContainerStyle>
                </TreeView>
            </Grid>
        </materialDesign:DrawerHost.LeftDrawerContent>

            <Grid>
                <ContentControl Content="{Binding CurrentView}"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                Margin="10" />
            </Grid>
        </materialDesign:DrawerHost>
    </materialDesign:DialogHost>
</mah:MetroWindow>